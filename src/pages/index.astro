---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
---

<Layout>
  <section
    class="px-3 sm:px-4 mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 justify-items-center"
  >
    <ProductCard
      title="Mini Conejita Ballerina"
      description="¡Esta adorable conejita bailarina está buscando un nuevo hogar! Viste un lindo vestido con lazos, su vestido se puede quitar."
      price="30"
      image="/Productos/ejemplo.webp"
      slug="conejita-bailarina"
    />

    <ProductCard
      title="Mini Conejita Punk"
      description="¡Esta adorable conejita punk está buscando un nuevo hogar! Viste un lindo overol con su gorrito con pompones, su overo y gorro se puede quitar."
      price="40"
      image="/Productos/ejemplo.webp"
      slug="conejita-punk"
    />

    <ProductCard
      title="Mini Conejita Ajolote"
      description="¡Esta adorable conejita punk está buscando un nuevo hogar! Viste un lindo overol con su gorrito con pompones, su overo y gorro se puede quitar."
      price="40"
      image="/Productos/ejemplo.webp"
      slug="conejita-ajolote"
    />
  </section>
</Layout>