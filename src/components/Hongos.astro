---

---

<section class="px-4 py-6 flex justify-center">
  <div
    class="bg-white rounded-4xl shadow-md max-w-4xl w-full flex flex-col md:flex-row overflow-hidden"
  >
    <!-- Imagen -->
    <div class="md:w-1/2 w-full px-5 py-5">
      <img
        src="/Productos/pulpos.webp"
        alt="Ranitas"
        class="w-full h-full object-cover rounded-3xl"
      />
    </div>

    <!-- Contenido -->
    <div class="md:w-1/2 w-full p-6 flex flex-col gap-4">
      <!-- Título -->
      <h1 class="text-2xl sm:text-3xl font-semibold text-gray-800">
        Honguitos
      </h1>

      <!-- Descripción -->
      <p class="text-gray-600 text-sm">
        ¡Estos adorables honguitos están buscando un nuevo hogar! Perfectos para
        darle un toque tierno y mágico a tu espacio o como un regalo único hecho
        a mano. Cada uno tiene su propio color y personalidad, inspirados en la
        naturaleza y en un estilo kawaii que los hace irresistibles.
        <br /><br />
        ♡ Hecha a mano<br />
        ♡ Altura: 8 cm<br />
        ♡ Material: Lana chenille extra suave<br />
      </p>

      <!-- Precio -->
      <p class="text-morado text-xl font-medium">El precio no incluye envio.</p>
      <p class="text-morado text-3xl font-bold">$5,5</p>

      <!-- Personalización -->
      <div>
        <h2 class="font-semibold text-gray-800">Personalización</h2>

        <p class="text-sm text-gray-600 mt-1">
          Puedes convertirlo en llavero y llevar tu honguito contigo a todas
          partes por $0.5 adicional Elige el color que mas te guste.
        </p>

        <!-- Opciones -->
        <div class="mt-3 text-sm text-gray-700">
          <!-- Vestido -->
          <p class="font-medium mt-4">Color</p>
          <div class="flex gap-3 mt-2">
            <label class="cursor-pointer">
              <input
                type="radio"
                name="color"
                value="Rosa"
                class="hidden peer"
              />
              <div
                title="Rosa"
                class="w-6 h-6 rounded-full bg-pink-300 peer-checked:border-2 peer-checked:border-morado peer-checked:scale-110 transition"
              >
              </div>
            </label>

            <label class="cursor-pointer">
              <input
                type="radio"
                name="color"
                value="rojo"
                class="hidden peer"
              />
              <div
                title="Morado"
                class="w-6 h-6 rounded-full bg-red-500 peer-checked:border-2 peer-checked:border-morado peer-checked:scale-110 transition"
              >
              </div>
            </label>

            <label class="cursor-pointer">
              <input
                type="radio"
                name="color"
                value="morado"
                class="hidden peer"
              />
              <div
                title="Morado"
                class="w-6 h-6 rounded-full bg-purple-300 peer-checked:border-2 peer-checked:border-morado peer-checked:scale-110 transition"
              >
              </div>
            </label>
          </div>
        </div>
      </div>

      <!-- Aviso -->
      <p class="text-xs text-gray-500 bg-gray-100 p-3 rounded-xl">
        Si alguno no está disponible en stock, te avisaremos directamente por
        WhatsApp para ofrecerte alternativas.
      </p>

      <!-- Botón -->
      <button
        id="whatsappBtn"
        class="mt-4 bg-morado text-white py-3 rounded-xl hover:bg-lila transition-colors w-full font-medium"
      >
        Pedir por WhatsApp
      </button>
    </div>
  </div>
</section>

<script>
  const phone = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
  const btn = document.getElementById("whatsappBtn");

  btn.addEventListener("click", () => {
    const color = document.querySelector('input[name="color"]:checked')?.value;

    if (!color) {
      alert("Por favor selecciona los colores antes de continuar 😊");
      return;
    }

    const producto = "Honguito";

    let mensaje = `Hola, me interesa el ${producto}`;

    mensaje += `\n\nPersonalización:`;
    mensaje += `\n- Color: ${color}`;

    const telefono = `${phone}`;
    const url = `https://wa.me/${telefono}?text=${encodeURIComponent(mensaje)}`;

    window.open(url, "_blank");
  });
</script>
