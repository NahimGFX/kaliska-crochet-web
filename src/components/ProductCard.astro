---
const { title, description, price, image, slug } = Astro.props;
---

<div
  class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-lg transition-all duration-300 flex max-w-130 w-full"
>
  <!-- Imagen -->
  <div class="w-1/2 aspect-square">
    <img
      src={image}
      alt={title}
      class="w-full h-full px-5 py-5 object-cover rounded-4xl"
    />
  </div>

  <!-- Contenido -->
  <div class="w-1/2 p-6 flex flex-col justify-between">
    <!-- Info -->
    <div>
      <h2 class="text-xl sm:text-2xl font-semibold text-gray-800 leading-tight">
        {title}
      </h2>

      <p class="mt-2 text-sm text-gray-500 line-clamp-3">
        {description}
      </p>

      <p class="mt-3 text-morado text-2xl sm:text-3xl font-bold">
        ${price}
      </p>
    </div>

    <!-- Botón -->
    <a
      href={`/${slug}`}
      class="mt-5 bg-morado text-white text-sm py-2 rounded-xl hover:bg-lila transition-colors text-center block"
    >
      Ver más
    </a>
  </div>
</div>
